# Application Configuration
APP_NAME="AI Product Authenticity Detection System"
APP_VERSION="1.0.0"
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=product_authenticity_db

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-this-in-production-make-it-very-long-and-random-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:8000","http://127.0.0.1:3000"]

# Admin Credentials (CHANGE IN PRODUCTION!)
DEFAULT_ADMIN_EMAIL=admin@authenticity.ai
DEFAULT_ADMIN_PASSWORD=Admin@123

# AI Models
DEVICE=cpu
VIT_MODEL_NAME=google/vit-base-patch16-224
OCR_GPU=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
